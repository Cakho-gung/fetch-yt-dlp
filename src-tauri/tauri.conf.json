{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "FETCH",
    "version": "0.1.0",
    "identifier": "com.fetch.downloader",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "FETCH — Mini Downloader",
                "width": 1160,
                "height": 756,
                "minWidth": 720,
                "minHeight": 560,
                "decorations": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "createUpdaterArtifacts": "v1Compatible"
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE4Q0I1NjNBNTk0QjI0NzEKUldSeEpFdFpPbGJMcUhzeHNLQTNoTnlSK0FHZWYwQ3ZQeXpmaEdTR3hJQWtwOVJJRHFtaFIwVGUK",
            "endpoints": [
                "https://github.com/Cakho-gung/fetch-yt-dlp/releases/latest/download/latest.json"
            ]
        }
    }
}
